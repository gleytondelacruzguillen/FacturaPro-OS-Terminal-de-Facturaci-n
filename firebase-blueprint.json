{
  "entities": {
    "Client": {
      "title": "Client",
      "description": "Customer information",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name"]
    },
    "Product": {
      "title": "Product",
      "description": "Product details",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "stock": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["code", "name", "price", "stock"]
    },
    "Invoice": {
      "title": "Invoice",
      "description": "Sales invoice",
      "type": "object",
      "properties": {
        "invoiceNumber": { "type": "integer" },
        "date": { "type": "string", "format": "date-time" },
        "paymentType": { "type": "string", "enum": ["Efectivo", "Transferencia", "Crédito"] },
        "client": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "phone": { "type": "string" },
            "address": { "type": "string" }
          }
        },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "code": { "type": "string" },
              "description": { "type": "string" },
              "quantity": { "type": "number" },
              "price": { "type": "number" },
              "subtotal": { "type": "number" }
            }
          }
        },
        "subtotal": { "type": "number" },
        "discount": { "type": "number" },
        "tax": { "type": "number" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["Pagada", "Pendiente"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["invoiceNumber", "date", "paymentType", "items", "total", "status"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Business configuration",
      "type": "object",
      "properties": {
        "businessName": { "type": "string" },
        "logo": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "taxPercentage": { "type": "number" },
        "currency": { "type": "string" }
      },
      "required": ["businessName", "currency"]
    }
  },
  "firestore": {
    "/users/{userId}/clients/{clientId}": {
      "schema": "Client",
      "description": "List of clients for a specific user business"
    },
    "/users/{userId}/products/{productId}": {
      "schema": "Product",
      "description": "Inventory of products for a specific user business"
    },
    "/users/{userId}/invoices/{invoiceId}": {
      "schema": "Invoice",
      "description": "Sales history for a specific user business"
    },
    "/users/{userId}/settings/current": {
      "schema": "Settings",
      "description": "Configuration for the business"
    }
  }
}
