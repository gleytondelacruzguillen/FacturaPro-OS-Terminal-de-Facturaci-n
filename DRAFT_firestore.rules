rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Common Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Entity Validations
    function isValidClient(data) {
      return data.keys().hasAll(['name']) && 
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             (!('phone' in data) || (data.phone is string && data.phone.size() <= 50)) &&
             (!('address' in data) || (data.address is string && data.address.size() <= 500)) &&
             (!('createdAt' in data) || data.createdAt == request.time);
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['code', 'name', 'price', 'stock']) &&
             data.code is string && data.code.size() <= 50 &&
             data.name is string && data.name.size() <= 200 &&
             data.price is number && data.price >= 0 &&
             data.stock is number &&
             (!('createdAt' in data) || data.createdAt == request.time);
    }

    function isValidInvoice(data) {
      return data.keys().hasAll(['invoiceNumber', 'date', 'paymentType', 'items', 'total', 'status']) &&
             data.invoiceNumber is int && data.invoiceNumber > 0 &&
             data.paymentType in ['Efectivo', 'Transferencia', 'Crédito'] &&
             data.status in ['Pagada', 'Pendiente'] &&
             data.items is list && data.items.size() <= 100 &&
             data.total is number && data.total >= 0 &&
             (!('createdAt' in data) || data.createdAt == request.time);
    }

    function isValidSettings(data) {
      return data.keys().hasAll(['businessName', 'currency']) &&
             data.businessName is string && data.businessName.size() <= 200 &&
             data.currency is string && data.currency.size() <= 10;
    }

    // Collection Rules
    match /users/{userId} {
      match /clients/{clientId} {
        allow read, list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(clientId) && isValidClient(incoming());
        allow update: if isOwner(userId) && isValidClient(incoming());
        allow delete: if isOwner(userId);
      }

      match /products/{productId} {
        allow read, list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(productId) && isValidProduct(incoming());
        allow update: if isOwner(userId) && isValidProduct(incoming());
        allow delete: if isOwner(userId);
      }

      match /invoices/{invoiceId} {
        allow read, list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(invoiceId) && isValidInvoice(incoming());
        allow update: if isOwner(userId) && isValidInvoice(incoming()) && 
                        incoming().diff(existing()).affectedKeys().hasOnly(['status', 'items', 'total', 'paymentType']); // Flexible for edits
        allow delete: if isOwner(userId);
      }

      match /settings/current {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) && isValidSettings(incoming());
      }
    }
  }
}
